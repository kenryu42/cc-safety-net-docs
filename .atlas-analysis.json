{
  "projectType": "cli-tool",
  "projectName": "CC Safety Net",
  "projectDescription": "A PreToolUse hook for AI coding agents that intercepts and blocks destructive git and filesystem commands before they execute, supporting Claude Code, OpenCode, Gemini CLI, Copilot CLI, Codex, Kimi Code, and Pi.",
  "theme": "luma",
  "primaryColor": "#40993e",
  "lightColor": "#183018",
  "darkColor": "#e4e8e4",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
