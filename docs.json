{
  "$schema": "https://mintlify.com/docs.json",
  "name": "CC Safety Net",
  "description": "Documentation for CC Safety Net, a PreToolUse hook that intercepts and blocks destructive git and filesystem commands before AI coding agents run them using semantic analysis that pattern matching and sandboxing cannot match.",
  "theme": "luma",
  "colors": {
    "primary": "#005f46",
    "light": "#5ee8b5",
    "dark": "#0f7a4d"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#f5f8f7",
      "dark": "#091c1e"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": false,
    "codeblocks": "dark"
  },
  "fonts": {
    "family": "Geist"
  },
  "icons": {
    "library": "lucide"
  },
  "metadata": {
    "timestamp": true
  },
  "seo": {
    "metatags": {
      "theme-color": "#005f46",
      "color-scheme": "light dark"
    }
  },
  "thumbnails": {
    "appearance": "dark"
  },
  "favicon": "/assets/favicon.svg",
  "logo": {
    "href": "/",
    "light": "/assets/cc-safety-net-header-logo-light.svg",
    "dark": "/assets/cc-safety-net-header-logo-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/kenryu42/cc-safety-net"
      },
      {
        "label": "Issues",
        "href": "https://github.com/kenryu42/cc-safety-net/issues"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/kenryu42/cc-safety-net"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/kenryu42/cc-safety-net"
    },
    "links": [
      {
        "header": "Get Started",
        "items": [
          { "label": "Introduction", "href": "/introduction" },
          { "label": "Installation", "href": "/installation" },
          { "label": "Quickstart", "href": "/quickstart" }
        ]
      },
      {
        "header": "Reference",
        "items": [
          { "label": "Blocked commands", "href": "/reference/blocked-commands" },
          { "label": "Allowed commands", "href": "/reference/allowed-commands" },
          { "label": "CLI commands", "href": "/reference/cli-commands" },
          { "label": "Glossary", "href": "/reference/glossary" }
        ]
      },
      {
        "header": "Project",
        "items": [
          { "label": "Contributing", "href": "/contributing" },
          { "label": "Security", "href": "/security" },
          { "label": "GitHub Issues", "href": "https://github.com/kenryu42/cc-safety-net/issues" }
        ]
      }
    ]
  },
  "banner": {
    "content": "For AI agents: read the complete documentation index at [`/llms.txt`](/llms.txt).",
    "dismissible": true,
    "type": "info"
  },
  "search": {
    "prompt": "Search commands, agents, and rules..."
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ],
    "display": "toc"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Configuration",
            "icon": "settings",
            "pages": [
              "configuration/modes",
              "configuration/environment",
              "configuration/custom-rules",
              "configuration/status-line"
            ]
          },
          {
            "group": "Reference",
            "icon": "book-open",
            "pages": [
              "reference/blocked-commands",
              "reference/allowed-commands",
              "reference/audit-log",
              "reference/cli-commands",
              "reference/explain-trace",
              "reference/glossary"
            ]
          },
          {
            "group": "Guides",
            "icon": "compass",
            "pages": [
              {
                "group": "Concepts",
                "icon": "lightbulb",
                "pages": [
                  "guides/how-it-works",
                  "guides/architecture",
                  "guides/analysis-engine",
                  "guides/design-principles",
                  "guides/security-model"
                ]
              },
              {
                "group": "Comparisons & integration",
                "icon": "git-compare",
                "pages": [
                  "guides/vs-permission-rules",
                  "guides/vs-sandboxing",
                  "guides/integration-architecture"
                ]
              },
              {
                "group": "Limits & troubleshooting",
                "icon": "triangle-alert",
                "pages": [
                  "guides/known-limitations",
                  "guides/troubleshooting"
                ]
              }
            ]
          },
          {
            "group": "Project",
            "icon": "hammer",
            "pages": [
              "contributing",
              "security"
            ]
          }
        ]
      }
    ]
  }
}
