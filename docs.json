{
  "$schema": "https://mintlify.com/docs.json",
  "name": "CC Safety Net",
  "theme": "luma",
  "colors": {
    "primary": "#34d399",
    "light": "#5ee8b5",
    "dark": "#f3f1db"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "dark": "#091c1e"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": false,
    "codeblocks": "dark"
  },
  "thumbnails": {
    "appearance": "dark"
  },
  "favicon": "/assets/favicon.svg",
  "logo": {
    "href": "/",
    "light": "/assets/cc-safety-net-header-logo-light.svg",
    "dark": "/assets/cc-safety-net-header-logo-dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/kenryu42/cc-safety-net"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/modes",
              "configuration/custom-rules",
              "configuration/status-line"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/blocked-commands",
              "reference/allowed-commands",
              "reference/cli-commands"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/how-it-works",
              "guides/vs-permission-rules",
              "guides/vs-sandboxing",
              "guides/troubleshooting"
            ]
          }
        ]
      }
    ]
  }
}
